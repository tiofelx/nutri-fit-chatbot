{
  "buildCommand": "npm run build",
  "outputDirectory": "frontend/dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" }
  ],
  "functions": {
    "backend/api/index.ts": {
      "runtime": "@vercel/node@3",
      "includeFiles": "backend/src/**"
    }
  }
}